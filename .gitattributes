# Force LF line endings for all text files
* text=auto eol=lf

# Python files — explicitly LF
*.py text eol=lf

# Shell scripts — explicitly LF
*.sh text eol=lf

# Markdown / documentation
*.md text eol=lf
*.rst text eol=lf

# Config files
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Binary files — don't normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
